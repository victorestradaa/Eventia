generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id              String     @id @default(cuid())
  email           String     @unique
  nombre          String
  telefono        String?
  rol             Rol
  stripeClienteId String?    @unique
  creadoEn        DateTime   @default(now())
  actualizadoEn   DateTime   @updatedAt
  cliente         Cliente?
  proveedor       Proveedor?
}

model Proveedor {
  id                      String            @id @default(cuid())
  usuarioId               String            @unique
  nombre                  String
  descripcion             String?
  categoria               CategoriaServicio
  ciudad                  String
  estado                  String
  direccion               String?
  latitud                 Float?
  longitud                Float?
  logoUrl                 String?
  bannerUrl               String?
  plan                    PlanProveedor     @default(GRATIS)
  stripeSubId             String?           @unique
  puntuacionExp           Int               @default(0)
  activo                  Boolean           @default(true)
  permiteReservasPorHora  Boolean           @default(false)
  horarioApertura         String            @default("09:00")
  horarioCierre           String            @default("23:00")
  horasExpiracionTemporal Int               @default(24)
  creadoEn                DateTime          @default(now())
  actualizadoEn           DateTime          @updatedAt
  complementos            Complemento[]
  portafolio              PortfolioItem[]
  usuario                 Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  resenas                 Resena[]
  reservas                Reserva[]
  servicios               Servicio[]
}

model Servicio {
  id                  String             @id @default(cuid())
  proveedorId         String
  nombre              String
  descripcion         String?
  precio              Decimal            @db.Decimal(10, 2)
  capacidadMin        Int?
  capacidadMax        Int?
  diasDisponibles     Int[]
  etiquetasEvento     TipoEvento[]
  imagenes            String[]
  videos              String[]
  capacidadSimultanea Int                @default(1)
  bloquesHorario      String[]
  activo              Boolean            @default(true)
  creadoEn            DateTime           @default(now())
  actualizadoEn       DateTime           @updatedAt
  lineasPresupuesto   LineaPresupuesto[]
  reservas            Reserva[]
  proveedor           Proveedor          @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  variaciones         VariacionPrecio[]
  complementos        Complemento[]      @relation("ComplementoToServicio")
}

model VariacionPrecio {
  id             String   @id @default(cuid())
  servicioId     String
  mes            Int
  precioOverride Decimal  @db.Decimal(10, 2)
  servicio       Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@unique([servicioId, mes])
}

model Complemento {
  id            String     @id @default(cuid())
  proveedorId   String
  nombre        String
  descripcion   String?
  precio        Decimal    @db.Decimal(10, 2)
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  proveedor     Proveedor  @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  servicios     Servicio[] @relation("ComplementoToServicio")
}

model PortfolioItem {
  id          String    @id @default(cuid())
  proveedorId String
  url         String
  tipo        String    @default("IMAGE")
  titulo      String?
  descripcion String?
  categoria   String?
  orden       Int       @default(0)
  creadoEn    DateTime  @default(now())
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
}

model Cliente {
  id            String      @id @default(cuid())
  usuarioId     String      @unique
  plan          PlanCliente @default(FREE)
  stripeSubId   String?     @unique
  trialExpira   DateTime?
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt
  ciudad        String      @default("Sin asignar")
  estado        String      @default("Sin asignar")
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  eventos       Evento[]
  resenas       Resena[]
  reservas      Reserva[]
}

model Evento {
  id                String             @id @default(cuid())
  clienteId         String
  nombre            String
  tipo              String
  fecha             DateTime?
  presupuestoTotal  Decimal            @default(0) @db.Decimal(10, 2)
  numInvitados      Int?
  descripcion       String?
  creadoEn          DateTime           @default(now())
  actualizadoEn     DateTime           @updatedAt
  estado            EstadoEvento       @default(ACTIVO)
  album             AlbumDigital?
  disposicionMesas  DisposicionMesa?
  cliente           Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  invitacion        InvitacionDigital?
  invitados         Invitado[]
  lineasPresupuesto LineaPresupuesto[]
  reservas          Reserva[]
}

model Invitado {
  id             String     @id @default(cuid())
  eventoId       String
  nombre         String
  email          String?
  telefono       String?
  mesaAsignada   Int?
  rsvpToken      String     @unique @default(cuid())
  rsvpEstado     EstadoRSVP @default(PENDIENTE)
  lado           String?
  categoria      String?
  tipoPersona    String?
  creadoEn       DateTime   @default(now())
  esGrupoTitular Boolean    @default(false)
  grupoTitularId String?
  evento         Evento     @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  grupoTitular   Invitado?  @relation("GrupoFamiliar", fields: [grupoTitularId], references: [id])
  grupoMiembros  Invitado[] @relation("GrupoFamiliar")
}

model LineaPresupuesto {
  id            String    @id @default(cuid())
  eventoId      String
  servicioId    String?
  descripcion   String
  montoTotal    Decimal   @db.Decimal(10, 2)
  montoPagado   Decimal   @default(0) @db.Decimal(10, 2)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  evento        Evento    @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  servicio      Servicio? @relation(fields: [servicioId], references: [id])
  pagos         Pago[]
}

model Pago {
  id      String           @id @default(cuid())
  lineaId String
  monto   Decimal          @db.Decimal(10, 2)
  nota    String?
  fecha   DateTime         @default(now())
  linea   LineaPresupuesto @relation(fields: [lineaId], references: [id], onDelete: Cascade)
}

model Reserva {
  id                     String        @id @default(cuid())
  clienteId              String?
  proveedorId            String
  servicioId             String
  eventoId               String?
  fechaEvento            DateTime
  tipoReserva            TipoReserva   @default(DIA_COMPLETO)
  horaInicio             String?
  horaFin                String?
  estado                 EstadoReserva @default(TEMPORAL)
  montoTotal             Decimal       @db.Decimal(10, 2)
  montoAnticipo          Decimal       @default(0) @db.Decimal(10, 2)
  montoComision          Decimal       @default(0) @db.Decimal(10, 2)
  notas                  String?
  stripePaymentId        String?
  esManual               Boolean       @default(false)
  nombreClienteExterno   String?
  telefonoClienteExterno String?
  fechaExpiracion        DateTime?
  turnoConfirmadoEn      DateTime?
  creadoEn               DateTime      @default(now())
  actualizadoEn          DateTime      @updatedAt
  cliente                Cliente?      @relation(fields: [clienteId], references: [id])
  evento                 Evento?       @relation(fields: [eventoId], references: [id])
  proveedor              Proveedor     @relation(fields: [proveedorId], references: [id])
  servicio               Servicio      @relation(fields: [servicioId], references: [id])
  transacciones          Transaccion[]
}

model Transaccion {
  id               String    @id @default(cuid())
  reservaId        String
  monto            Decimal   @db.Decimal(10, 2)
  comision         Decimal   @default(0) @db.Decimal(10, 2)
  tipo             String    @default("ABONO")
  metodoPago       String    @default("STRIPE")
  estado           String    @default("PAGADO")
  fechaVencimiento DateTime?
  fechaPago        DateTime? @default(now())
  stripePaymentId  String?
  notas            String?
  creadoEn         DateTime  @default(now())
  reserva          Reserva   @relation(fields: [reservaId], references: [id], onDelete: Cascade)
}

model Resena {
  id           String    @id @default(cuid())
  proveedorId  String
  clienteId    String
  calificacion Int
  comentario   String?
  creadoEn     DateTime  @default(now())
  cliente      Cliente   @relation(fields: [clienteId], references: [id])
  proveedor    Proveedor @relation(fields: [proveedorId], references: [id])
}

model DisposicionMesa {
  id            String   @id @default(cuid())
  eventoId      String   @unique
  layout        Json
  actualizadoEn DateTime @updatedAt
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
}

model InvitacionDigital {
  id                 String    @id @default(cuid())
  eventoId           String    @unique
  plantilla          String    @default("clasica")
  titulo             String
  mensaje            String?
  lugarTexto         String?
  vestimenta         String?
  enviadaEn          DateTime?
  rsvpFecha          DateTime?
  isInvitacionPropia Boolean   @default(false)
  archivoAdjunto     String?
  fondoUrl           String?
  colorTexto         String?   @default("#ffffff")
  fuente             String?
  direccion          String?
  regaloTipo         String?
  regaloMesaUrl      String?
  regaloBanco        String?
  regaloClabe        String?
  tipoInvitacion     String    @default("BASICA")
  configWeb          Json?
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt
  evento             Evento    @relation(fields: [eventoId], references: [id], onDelete: Cascade)
}

model CatalogoAsset {
  id            String   @id @default(cuid())
  tipo          String
  categoria     String
  nombre        String
  url           String
  etiquetas     String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model AlbumDigital {
  id            String       @id @default(cuid())
  eventoId      String       @unique
  nombre        String?
  slug          String       @unique
  activo        Boolean      @default(true)
  config        Json?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
  evento        Evento       @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  media         AlbumMedia[]
}

model AlbumMedia {
  id            String       @id @default(cuid())
  albumId       String
  url           String
  tipo          String
  nombreArchivo String?
  tamanio       Int?
  creadoEn      DateTime     @default(now())
  album         AlbumDigital @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

enum EstadoEvento {
  ACTIVO
  ARCHIVADO
  COMPLETADO
}

enum Rol {
  PROVEEDOR
  CLIENTE
  ADMIN
}

enum PlanProveedor {
  GRATIS
  INTERMEDIO
  PREMIUM
  ELITE
}

enum PlanCliente {
  FREE
  ORO
  PLANNER
}

enum CategoriaServicio {
  SALON
  MUSICA
  COMIDA
  ANIMACION
  FOTOGRAFIA
  DECORACION
  RECUERDOS
  MOBILIARIO
  PAQUETES_COMPLETOS
}

enum TipoEvento {
  BODA
  XV_ANOS
  BAUTIZO
  FIESTA_INFANTIL
  FIESTA_GENERAL
  TODOS
}

enum TipoReserva {
  DIA_COMPLETO
  POR_HORAS
}

enum EstadoReserva {
  TEMPORAL
  APARTADO
  LIQUIDADO
  CANCELADO
}

enum EstadoRSVP {
  PENDIENTE
  CONFIRMADO
  RECHAZADO
}
